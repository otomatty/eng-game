# === Cloudflare デプロイ用（wrangler / opennextjs-cloudflare deploy） ===
# ローカルで `wrangler login` を使う場合は不要。
# CI など非対話環境から本番 D1 への適用・デプロイを行う場合のみ設定する。
#
# API トークンは Cloudflare ダッシュボード > My Profile > API Tokens で発行し、
# 「D1 Edit」「Workers Scripts Edit」権限を付与する。
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === ログイン総当たり対策（レート制限 / Issue #5） ===
# IP+メール単位で、WINDOW 秒内に MAX_FAILURES 回失敗したら LOCK 秒ロックする。
# 未設定なら既定値（5 回 / 900 秒窓 / 900 秒ロック）。
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW_SEC=900
LOGIN_RATE_LIMIT_LOCK_SEC=900
